{
  "name": "xmcrud",
  "version": "1.3.1",
  "description": "A lightweight helper library for building Express.js routes, controllers, advanced query with mongoose, and Redis-enhanced middleware with optional Redis support.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "readmeFilename": "README.md",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "xmcrud": "./dist/cli.js"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc && ts-node scripts/copyTemplates.ts",
    "copy-templates": "cp -r src/templates dist/templates",
    "dev": "ts-node src/index.ts",
    "clean": "rm -rf dist",
    "prepare": "yarn build",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "jest",
    "optimize-seo": "npm-seo-optimize"
  },
  "keywords": [
    "express",
    "middleware",
    "redis",
    "express-helper",
    "controller",
    "router",
    "express-router",
    "typescript",
    "rest",
    "api",
    "express-smart-helper",
    "curd",
    "xmcrud",
    "express helper",
    "crud",
    "mongoose-crud",
    "express-crud",
    "rest-crud",
    "rest-api-generator",
    "express-api",
    "express-crud-generator",
    "auto-crud",
    "crud-generator",
    "mongodb-crud"
  ],
  "author": "Suronjit Pal (suronjit797)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/suronjit797/express-smart-helper.git"
  },
  "bugs": {
    "url": "https://github.com/suronjit797/express-smart-helper/issues"
  },
  "homepage": "https://github.com/suronjit797/express-smart-helper#readme",
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^24.8.1",
    "eslint": "^9.38.0",
    "jest": "^30.2.0",
    "npm-seo-optimizer": "^1.0.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "dayjs": ">=1.11.18",
    "express": ">=4.0.0",
    "fs-extra": "^11.3.2",
    "ioredis": ">=5.0.0",
    "mongoose": ">=6.0.0"
  },
  "engines": {
    "node": ">=16.0.0 "
  }
}
